# Project secrets & credentials (never commit)
.access.deploy
.access.config
.access.*

# Laravel env (keep example committed)
.env
.env.*
!.env.example

# Local backups / mirrored folders (never commit)
backup/
backup/**

# Dependencies / build output
/vendor/
/node_modules/
/public/build/
/public/hot/
/public/storage

# Runtime / caches
/.phpunit.result.cache
/.phpunit.cache/
/storage/*.key
/storage/pail
/storage/logs/
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/views/

# Logs
*.log
spam-blocked.log

# Editor
/.vscode/
/.idea/
*.swp
*.swo
/.zed/
/.fleet/
/.nova/
.phpactor.json

# OS
.DS_Store
Thumbs.db
